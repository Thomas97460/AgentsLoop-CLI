# Python agent workflow settings.
#
# Copy to agents/.env when local Git operations need an explicit SSH key.
# AGENTS_* variables are preferred. Legacy N8N_* names are still accepted by
# the Python runner as a migration fallback, but should not be used for new setup.

# AGENTS_GIT_SSH_KEY_PATH=/home/your-user/.ssh/id_ed25519
# AGENTS_GIT_SSH_STRICT_HOST_KEY_CHECKING=accept-new
# AGENTS_GIT_SSH_KNOWN_HOSTS=/home/your-user/.ssh/known_hosts
